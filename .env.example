# ══════════════════════════════════════════════════════
#  Fitness Bro — Environment Configuration
#  Copy this file to .env and fill in your credentials
#  NEVER commit .env to version control!
# ══════════════════════════════════════════════════════

# ── IBM Cloud / Watsonx.ai Credentials ──────────────
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_api_key

# Get your Project ID from: https://dataplatform.cloud.ibm.com/
IBM_PROJECT_ID=your_project_id

# Watsonx.ai endpoint URL (default: US South)
# Options: https://us-south.ml.cloud.ibm.com
#          https://eu-gb.ml.cloud.ibm.com
#          https://eu-de.ml.cloud.ibm.com
#          https://jp-tok.ml.cloud.ibm.com
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
# ── IBM Granite Model ID ─────────────────────────────
# Recommended: ibm/granite-13b-instruct-v2
# Alternatives: ibm/granite-3-8b-instruct
#               ibm/granite-20b-multilingual
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2
# ── Flask Configuration ──────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_DEBUG=false
